# Copy this file to .env.local and fill in your own Gemini API keys.
# This project auto-loads .env.local at runtime, and .env.local is ignored by git.
#
# Key usage:
# - scripts/llm_query.py loads GEMINI_API_KEY_1/2/3 in order and falls back
#   from key 1 -> key 2 -> key 3.
# - ui/comparison_ui.py uses the same three keys for its 5-way comparison UI.
# - Provide at least one valid key; all three are optional but recommended.

GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Optional: override the default model used by scripts/llm_query.py
# LLM_MODEL=gemini-2.5-flash
